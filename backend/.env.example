# 服务监听
APP_HOST=0.0.0.0
APP_PORT=8000

# SmartCare 数据库
SMARTCARE_DB_HOST=127.0.0.1
SMARTCARE_DB_PORT=27017
SMARTCARE_DB_USER=your_user
SMARTCARE_DB_PASSWORD=your_password
SMARTCARE_DB_AUTH=SmartCare

# DataCenter 数据库
DATACENTER_DB_HOST=127.0.0.1
DATACENTER_DB_PORT=27017
DATACENTER_DB_USER=your_user
DATACENTER_DB_PASSWORD=your_password
DATACENTER_DB_AUTH=DataCenter

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# AI/LLM
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_API_KEY=your_api_key
LLM_MODEL=
LLM_MODEL_MEDICAL=
LLM_FALLBACK_MODEL=
LLM_REASONING_MODEL=

# ASR（语音识别）
ASR_BASE_URL=http://127.0.0.1:10096
ASR_MODE=http                    # http（OpenAI 兼容 API）| ws（FunASR 原生 WebSocket 协议）

# ASR 语音纠错专用 LLM（留空则 fallback 到全局 LLM 配置）
ASR_LLM_BASE_URL=
ASR_LLM_API_KEY=
ASR_LLM_MODEL=

# 系统
SECRET_KEY=change-me-in-production

# 安全（可选）
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
WEBSOCKET_TOKENS=
WEBSOCKET_REQUIRE_TOKEN=
